# ===============================
# APP
# ===============================
APP_NAME=MyApp
APP_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
APP_DEBUG=true

# ===============================
# SERVER
# ===============================
HOST=0.0.0.0
PORT=3000

# ===============================
# DATABASE
# ===============================
DB_CLIENT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# MYSQL EXAMPLE
# DB_CLIENT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=myapp_db
# DB_USER=root
# DB_PASSWORD=root

# ===============================
# REDIS / CACHE
# ===============================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_DRIVER=redis

# ===============================
# AUTH / JWT
# ===============================
JWT_SECRET=supersecretkey
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=refreshsecret
JWT_REFRESH_EXPIRES_IN=7d

# ===============================
# SESSION
# ===============================
SESSION_SECRET=sessionsecret
SESSION_EXPIRES=86400000

# ===============================
# EMAIL (SMTP)
# ===============================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=yourpassword
MAIL_FROM="MyApp <noreply@myapp.com>"

# ===============================
# STORAGE
# ===============================
STORAGE_DRIVER=local

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=myapp-bucket

# ===============================
# OAUTH / LOGIN SOCIAL
# ===============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ===============================
# SECURITY
# ===============================
BCRYPT_SALT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ===============================
# API
# ===============================
API_PREFIX=/api
API_VERSION=v1

# ===============================
# LOGS
# ===============================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ===============================
# THIRD PARTY SERVICES
# ===============================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===============================
# FRONTEND
# ===============================
FRONTEND_URL=http://localhost:5173

# ===============================
# FEATURE FLAGS
# ===============================
FEATURE_SIGNUP=true
FEATURE_PAYMENTS=false

# ===============================
# CRON / JOBS
# ===============================
CRON_ENABLED=true
CRON_TIMEZONE=UTC
